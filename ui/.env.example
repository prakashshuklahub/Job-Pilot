# Shared Supabase project (local dev + Vercel prod — same data)
# Root ../.env is loaded automatically; override here only if needed.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Dashboard gate — required in production (all pages + /api/* except /api/auth/* and cron)
# UI_PASSWORD=choose-a-strong-password

# Vercel Cron auth (Vercel sets this on Pro; set manually for local cron tests)
# CRON_SECRET=generate-a-long-random-string
